    "builtin-modules": "5.0.0",
    "esbuild": "0.27.2",
    "happy-dom": "^20.8.9",
    "obsidian": "latest",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "tslib": "2.8.1",
    "typescript": "5.9.3",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
